#:kivy 2.0.0

<LoginScreen>:
    canvas.before:
        Color:
            rgba: app.page_bg
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "horizontal"

        # ---------- left brand panel ----------
        BoxLayout:
            orientation: "vertical"
            size_hint_x: 0.45
            padding: 56, 56
            spacing: 14
            canvas.before:
                Color:
                    rgba: 0.118, 0.157, 0.231, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.231, 0.318, 0.882, 0.30
                Ellipse:
                    pos: self.right - 240, self.top - 240
                    size: 320, 320
                Color:
                    rgba: 0.122, 0.659, 0.412, 0.20
                Ellipse:
                    pos: self.x - 80, self.y - 60
                    size: 260, 260

            BoxLayout:
                size_hint_y: None
                height: 56
                spacing: 12
                Widget:
                    size_hint_x: None
                    width: 56
                    canvas:
                        Color:
                            rgba: 0.231, 0.318, 0.882, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12,]
                        Color:
                            rgba: 1, 1, 1, 1
                        Line:
                            points: self.x + 14, self.y + 14, self.x + 14, self.y + 42, self.x + 42, self.y + 42
                            width: 2.4
                        Line:
                            points: self.x + 20, self.y + 32, self.x + 28, self.y + 24, self.x + 36, self.y + 32
                            width: 2.4
                Label:
                    text: "LogicTrack"
                    color: 1, 1, 1, 1
                    font_size: 28
                    bold: True
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

            Widget:
                size_hint_y: None
                height: 18

            Label:
                text: "Inventory, simplified."
                color: 1, 1, 1, 1
                font_size: 32
                bold: True
                halign: "left"
                valign: "top"
                text_size: self.size
                size_hint_y: None
                height: 48

            Label:
                text: "Track stock, monitor low-stock alerts, manage suppliers and generate reports — all from one polished dashboard."
                color: 0.78, 0.83, 0.91, 1
                font_size: 15
                halign: "left"
                valign: "top"
                text_size: self.size

            Widget:

            Label:
                text: "© 2026 LogicTrack. All rights reserved."
                color: 0.55, 0.62, 0.74, 1
                font_size: 12
                size_hint_y: None
                height: 18
                halign: "left"
                valign: "middle"
                text_size: self.size

        # ---------- right login form ----------
        AnchorLayout:
            anchor_x: "center"
            anchor_y: "center"

            BoxLayout:
                orientation: "vertical"
                size_hint: None, None
                size: 420, 460
                spacing: 14

                Label:
                    text: "Welcome back"
                    color: app.text_color
                    font_size: 26
                    bold: True
                    size_hint_y: None
                    height: 36
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Label:
                    text: "Sign in to manage your inventory."
                    color: app.muted_text_color
                    font_size: 14
                    size_hint_y: None
                    height: 22
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Widget:
                    size_hint_y: None
                    height: 6

                Label:
                    text: "Username"
                    color: app.text_color
                    font_size: 13
                    bold: True
                    size_hint_y: None
                    height: 20
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                StyledInput:
                    id: username_input
                    hint_text: "you@logic.com  or  admin"
                    on_text: root.validate_username(self.text)
                    on_text_validate: password_input.focus = True

                Label:
                    text: "Password"
                    color: app.text_color
                    font_size: 13
                    bold: True
                    size_hint_y: None
                    height: 20
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                StyledInput:
                    id: password_input
                    hint_text: "Enter your password"
                    password: True
                    on_text_validate: root.do_login(username_input.text, self.text)

                PrimaryButton:
                    text: "Sign in"
                    height: 50
                    font_size: 15
                    on_release: root.do_login(username_input.text, password_input.text)

                Toast:
                    id: toast
                    visible: False

                Label:
                    id: error_label
                    text: ""
                    color: app.danger
                    font_size: 13
                    size_hint_y: None
                    height: 20
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

                Widget:
                    size_hint_y: None
                    height: 4

                Label:
                    text: "Demo accounts:  admin / admin   ·   manager / manager   ·   staff / staff"
                    color: app.muted_text_color
                    font_size: 12
                    size_hint_y: None
                    height: 18
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
