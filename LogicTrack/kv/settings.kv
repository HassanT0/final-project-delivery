#:kivy 2.0.0

<SettingsScreen>:
    canvas.before:
        Color:
            rgba: app.page_bg
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "horizontal"

        Sidebar:
            BoxLayout:
                size_hint_y: None
                height: 64
                padding: 22, 0
                spacing: 10
                Widget:
                    size_hint_x: None
                    width: 36
                    canvas:
                        Color:
                            rgba: app.primary
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [9,]
                        Color:
                            rgba: 1, 1, 1, 1
                        Line:
                            points: self.x + 9, self.y + 9, self.x + 9, self.y + 27, self.x + 27, self.y + 27
                            width: 1.8
                        Line:
                            points: self.x + 13, self.y + 22, self.x + 18, self.y + 17, self.x + 23, self.y + 22
                            width: 1.8
                Label:
                    text: "LogicTrack"
                    color: 1, 1, 1, 1
                    font_size: 19
                    bold: True
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

            Widget:
                size_hint_y: None
                height: 12
            Label:
                text: "MENU"
                color: 0.55, 0.62, 0.74, 1
                font_size: 11
                bold: True
                size_hint_y: None
                height: 22
                halign: "left"
                valign: "middle"
                text_size: self.size
                padding: 22, 0

            NavButton:
                label_text: "Dashboard"
                icon_glyph: ""
                icon_fallback: "D"
                on_release: root.manager.current = "dashboard"
            NavButton:
                label_text: "Inventory"
                icon_glyph: ""
                icon_fallback: "I"
                on_release: root.manager.current = "inventory"
            NavButton:
                label_text: "Suppliers"
                icon_glyph: ""
                icon_fallback: "S"
                on_release: root.manager.current = "suppliers"
            NavButton:
                label_text: "Reports"
                icon_glyph: ""
                icon_fallback: "R"
                on_release: root.manager.current = "reports"
            NavButton:
                label_text: "Settings"
                icon_glyph: ""
                icon_fallback: "C"
                active: True

            Widget:

            BoxLayout:
                size_hint_y: None
                height: 56
                padding: 14, 4
                Button:
                    text: "[font=" + app.icon_font + "][size=18][/size][/font]    Log out" if app.icon_font != "Roboto" else "L  Log out"
                    markup: app.icon_font != "Roboto"
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 0.95, 0.55, 0.55, 1
                    font_size: 14
                    bold: True
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                    padding: [22, 0]
                    on_release:
                        app.current_user = None
                        root.manager.current = "login"
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.05
                        RoundedRectangle:
                            pos: (self.x + 12, self.y + 3)
                            size: (self.width - 24, self.height - 6)
                            radius: [8,]

        BoxLayout:
            orientation: "vertical"

            TopBar:
                title: "Settings"
                subtitle: "Manage users, alerts, theme, and formatting."

            ScrollView:
                do_scroll_x: False
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 28, 20
                    spacing: 18

                    # ============ User Management ============
                    Card:
                        size_hint_y: None
                        height: self.minimum_height
                        Label:
                            text: "User management"
                            color: app.text_color
                            bold: True
                            font_size: 16
                            size_hint_y: None
                            height: 26
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: "Add and review accounts that can sign in to LogicTrack."
                            color: app.muted_text_color
                            font_size: 12
                            size_hint_y: None
                            height: 18
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        BoxLayout:
                            id: users_box
                            orientation: "vertical"
                            size_hint_y: None
                            height: self.minimum_height
                            spacing: 4
                        SuccessButton:
                            text: "+ Add user"
                            size_hint_x: None
                            width: 160

                            on_release: root.open_add_user()

                    # ============ Low-Stock Threshold ============
                    Card:
                        size_hint_y: None
                        height: 230
                        Label:
                            text: "Low-stock threshold"
                            color: app.text_color
                            bold: True
                            font_size: 16
                            size_hint_y: None
                            height: 26
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            id: threshold_label
                            text: "Global threshold: 5 units"
                            color: app.muted_text_color
                            font_size: 13
                            size_hint_y: None
                            height: 22
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Slider:
                            id: threshold_slider
                            min: 1
                            max: 50
                            step: 1
                            value: 5
                            size_hint_y: None
                            height: 36
                            on_value: root.update_threshold(self.value)
                        BoxLayout:
                            size_hint_y: None
                            height: 44
                            NeutralButton:
                                id: notifications_toggle
                                text: "Enable notifications: ON"
                                size_hint_x: None
                                width: 260
                                on_release: root.toggle_notifications()
                            Widget:

                    # ============ Theme ============
                    Card:
                        size_hint_y: None
                        height: 170
                        Label:
                            id: theme_label
                            text: "Appearance"
                            color: app.text_color
                            bold: True
                            font_size: 16
                            size_hint_y: None
                            height: 26
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        Label:
                            text: "Switch between light and dark presentation."
                            color: app.muted_text_color
                            font_size: 12
                            size_hint_y: None
                            height: 18
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        BoxLayout:
                            size_hint_y: None
                            height: 50
                            spacing: 12
                            NeutralButton:
                                id: light_btn
                                text: "Light mode"
                                size_hint_x: None
                                width: 180
                                on_release: root.set_theme("Light")
                            NeutralButton:
                                id: dark_btn
                                text: "Dark mode"
                                size_hint_x: None
                                width: 180
                                on_release: root.set_theme("Dark")
                            Widget:

                    # ============ Date & Time Format ============
                    Card:
                        size_hint_y: None
                        height: 230
                        Label:
                            text: "Date & time format"
                            color: app.text_color
                            bold: True
                            font_size: 16
                            size_hint_y: None
                            height: 26
                            halign: "left"
                            valign: "middle"
                            text_size: self.size
                        BoxLayout:
                            size_hint_y: None
                            height: 60
                            spacing: 12
                            Label:
                                text: "Date format"
                                color: app.text_color
                                font_size: 13
                                size_hint_x: None
                                width: 140
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            StyledInput:
                                id: date_format_input
                                text: "MM/DD/YYYY"
                                hint_text: "MM/DD/YYYY or DD/MM/YYYY"
                        BoxLayout:
                            size_hint_y: None
                            height: 60
                            spacing: 12
                            Label:
                                text: "Time format"
                                color: app.text_color
                                font_size: 13
                                size_hint_x: None
                                width: 140
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            StyledInput:
                                id: time_format_input
                                text: "12-hour"
                                hint_text: "12-hour or 24-hour"

                    PrimaryButton:
                        text: "Save changes"
                        size_hint_y: None
                        height: 50
                        font_size: 15
                        on_release: root.save_changes()
