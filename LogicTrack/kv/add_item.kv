#:kivy 2.0.0

<AddItemScreen>:
    canvas.before:
        Color:
            rgba: app.page_bg
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "vertical"

        TopBar:
            title: "Add new item"
            subtitle: "Enter product details and an optional image."
            NeutralButton:
                text: "Cancel"
                size_hint_x: None
                width: 110
                on_release: root.manager.current = "inventory"
            SuccessButton:
                text: "Save item"
                size_hint_x: None
                width: 140
                on_release: root.save_item()

        ScrollView:
            do_scroll_x: False
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                padding: 28, 20
                spacing: 16

                Card:
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 14

                    Label:
                        text: "Product details"
                        color: app.text_color
                        bold: True
                        font_size: 16
                        size_hint_y: None
                        height: 24
                        halign: "left"
                        valign: "middle"
                        text_size: self.size

                    BoxLayout:
                        size_hint_y: None
                        height: 220
                        spacing: 20

                        # Image preview column
                        BoxLayout:
                            orientation: "vertical"
                            size_hint_x: None
                            width: 220
                            spacing: 8
                            Image:
                                id: preview_image
                                source: "assets/icons/default.png"
                                size_hint_y: None
                                height: 180
                                allow_stretch: True
                                keep_ratio: True
                                canvas.before:
                                    Color:
                                        rgba: app.input_bg
                                    RoundedRectangle:
                                        pos: self.pos
                                        size: self.size
                                        radius: [12,]
                            NeutralButton:
                                text: "Upload image"
                                on_release: root.open_image_chooser()
                            Label:
                                id: image_path_label
                                text: "No image selected"
                                color: app.muted_text_color
                                font_size: 11
                                size_hint_y: None
                                height: 16
                                halign: "center"
                                valign: "middle"
                                text_size: self.size
                                shorten: True

                        # Form fields column
                        BoxLayout:
                            orientation: "vertical"
                            spacing: 10
                            BoxLayout:
                                spacing: 12
                                BoxLayout:
                                    orientation: "vertical"
                                    spacing: 4
                                    Label:
                                        text: "Item name"
                                        color: app.muted_text_color
                                        font_size: 12
                                        bold: True
                                        size_hint_y: None
                                        height: 16
                                        halign: "left"
                                        valign: "middle"
                                        text_size: self.size
                                    StyledInput:
                                        id: name_input
                                        hint_text: "e.g. Apples"
                                BoxLayout:
                                    orientation: "vertical"
                                    spacing: 4
                                    Label:
                                        text: "SKU"
                                        color: app.muted_text_color
                                        font_size: 12
                                        bold: True
                                        size_hint_y: None
                                        height: 16
                                        halign: "left"
                                        valign: "middle"
                                        text_size: self.size
                                    StyledInput:
                                        id: sku_input
                                        hint_text: "SKU001"
                                        on_text: root.validate_sku(self.text)
                            BoxLayout:
                                spacing: 12
                                BoxLayout:
                                    orientation: "vertical"
                                    spacing: 4
                                    Label:
                                        text: "Price ($)"
                                        color: app.muted_text_color
                                        font_size: 12
                                        bold: True
                                        size_hint_y: None
                                        height: 16
                                        halign: "left"
                                        valign: "middle"
                                        text_size: self.size
                                    StyledInput:
                                        id: price_input
                                        input_filter: "float"
                                        hint_text: "0.00"
                                BoxLayout:
                                    orientation: "vertical"
                                    spacing: 4
                                    Label:
                                        text: "Initial quantity"
                                        color: app.muted_text_color
                                        font_size: 12
                                        bold: True
                                        size_hint_y: None
                                        height: 16
                                        halign: "left"
                                        valign: "middle"
                                        text_size: self.size
                                    StyledInput:
                                        id: qty_input
                                        input_filter: "int"
                                        hint_text: "0"
                            BoxLayout:
                                orientation: "vertical"
                                spacing: 4
                                Label:
                                    text: "Category"
                                    color: app.muted_text_color
                                    font_size: 12
                                    bold: True
                                    size_hint_y: None
                                    height: 16
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size
                                StyledInput:
                                    id: category_input
                                    hint_text: "e.g. Produce, Dairy, Grains"

                    Toast:
                        id: toast
                        visible: False

                    Label:
                        id: error_label
                        text: ""
                        color: app.danger
                        font_size: 13
                        size_hint_y: None
                        height: 22
                        halign: "left"
                        valign: "middle"
                        text_size: self.size
