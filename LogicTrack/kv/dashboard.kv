#:kivy 2.0.0

<DashboardScreen>:
    canvas.before:
        Color:
            rgba: app.page_bg
        Rectangle:
            pos: self.pos
            size: self.size

    BoxLayout:
        orientation: "horizontal"

        # ============================================================
        # SIDEBAR — Material Design glyphs replace text-only labels
        # ============================================================
        Sidebar:
            BoxLayout:
                size_hint_y: None
                height: 64
                padding: 22, 0
                spacing: 10
                Widget:
                    size_hint_x: None
                    width: 36
                    canvas:
                        Color:
                            rgba: app.primary
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [9,]
                        Color:
                            rgba: 1, 1, 1, 1
                        Line:
                            points: self.x + 9, self.y + 9, self.x + 9, self.y + 27, self.x + 27, self.y + 27
                            width: 1.8
                        Line:
                            points: self.x + 13, self.y + 22, self.x + 18, self.y + 17, self.x + 23, self.y + 22
                            width: 1.8
                Label:
                    text: "LogicTrack"
                    color: 1, 1, 1, 1
                    font_size: 18
                    bold: True
                    halign: "left"
                    valign: "middle"
                    text_size: self.size

            Widget:
                size_hint_y: None
                height: 14

            Label:
                text: "MENU"
                color: 0.55, 0.62, 0.74, 1
                font_size: 11
                bold: True
                size_hint_y: None
                height: 22
                halign: "left"
                valign: "middle"
                text_size: self.size
                padding: 22, 0

            NavButton:
                label_text: "Dashboard"
                icon_glyph: ""
                icon_fallback: "[]"
                active: True
            NavButton:
                label_text: "Inventory"
                icon_glyph: ""
                icon_fallback: "[#]"
                on_release: root.manager.current = "inventory"
            NavButton:
                label_text: "Suppliers"
                icon_glyph: ""
                icon_fallback: ">>"
                on_release: root.manager.current = "suppliers"
            NavButton:
                label_text: "Reports"
                icon_glyph: ""
                icon_fallback: "II"
                on_release: root.manager.current = "reports"
            NavButton:
                label_text: "Settings"
                icon_glyph: ""
                icon_fallback: "*"
                on_release: root.manager.current = "settings"

            Widget:

            BoxLayout:
                size_hint_y: None
                height: 56
                padding: 14, 4
                Button:
                    text: "[font=" + app.icon_font + "][size=18][/size][/font]    Log out" if app.icon_font != "Roboto" else "->  Log out"
                    markup: True
                    background_normal: ""
                    background_color: 0, 0, 0, 0
                    color: 0.95, 0.55, 0.55, 1
                    font_size: 14
                    bold: True
                    halign: "left"
                    valign: "middle"
                    text_size: self.size
                    padding: [22, 0]
                    on_release:
                        app.current_user = None
                        root.manager.current = "login"
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 0.05
                        RoundedRectangle:
                            pos: (self.x + 12, self.y + 3)
                            size: (self.width - 24, self.height - 6)
                            radius: [8,]

        # ============================================================
        # MAIN
        # ============================================================
        BoxLayout:
            orientation: "vertical"

            TopBar:
                title: "Dashboard"
                subtitle: "Snapshot of inventory health and recent activity."
                StyledInput:
                    id: search_input
                    size_hint_x: None
                    width: 320
                    hint_text: "Search products..."
                    on_text_validate: root.search_products(self.text)

            ScrollView:
                do_scroll_x: False
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    padding: 28, 24
                    spacing: 20

                    # ---------- KPI row ----------
                    BoxLayout:
                        size_hint_y: None
                        height: 110
                        spacing: 18
                        KpiTile:
                            id: kpi_total
                            title: "TOTAL ITEMS"
                            value: "0"
                        KpiTile:
                            id: kpi_low
                            title: "LOW STOCK"
                            value: "0"
                            value_color: app.danger
                        KpiTile:
                            id: kpi_value
                            title: "INVENTORY VALUE"
                            value: "$0.00"
                            value_color: app.success
                        KpiTile:
                            id: kpi_suppliers
                            title: "SUPPLIERS"
                            value: "0"
                            value_color: app.info

                    # ---------- alerts banner ----------
                    Card:
                        id: alerts_card
                        size_hint_y: None
                        height: 230
                        BoxLayout:
                            size_hint_y: None
                            height: 26
                            Label:
                                text: "Low-stock alerts"
                                color: app.text_color
                                font_size: 16
                                bold: True
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            Label:
                                id: alerts_subtitle
                                text: ""
                                color: app.muted_text_color
                                font_size: 12
                                halign: "right"
                                valign: "middle"
                                text_size: self.size
                        ScrollView:
                            do_scroll_y: False
                            BoxLayout:
                                id: alerts_box
                                orientation: "horizontal"
                                size_hint_x: None
                                width: max(self.minimum_width, self.parent.width if self.parent else 0)
                                spacing: 14
                                padding: 0, 6

                    # ---------- recent restocks + quick actions ----------
                    BoxLayout:
                        size_hint_y: None
                        height: 360
                        spacing: 18

                        Card:
                            size_hint_x: 0.62
                            BoxLayout:
                                size_hint_y: None
                                height: 26
                                Label:
                                    text: "Recent restocks"
                                    color: app.text_color
                                    font_size: 16
                                    bold: True
                                    halign: "left"
                                    valign: "middle"
                                    text_size: self.size
                            BoxLayout:
                                id: restocks_box
                                orientation: "vertical"
                                spacing: 0

                        Card:
                            size_hint_x: 0.38
                            Label:
                                text: "Quick actions"
                                color: app.text_color
                                font_size: 16
                                bold: True
                                size_hint_y: None
                                height: 26
                                halign: "left"
                                valign: "middle"
                                text_size: self.size
                            PrimaryButton:
                                text: "+ Add new item"
                                on_release: root.manager.current = "add_item"
                            SuccessButton:
                                text: "Manage suppliers"
                                on_release: root.manager.current = "suppliers"
                            InfoButton:
                                text: "Generate report"
                                on_release: root.manager.current = "reports"
                            NeutralButton:
                                text: "Open settings"
                                on_release: root.manager.current = "settings"
                            Widget:
